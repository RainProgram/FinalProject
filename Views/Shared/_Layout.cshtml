@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Localization
@using EventRescue.Models
@using EventRescue.Models.Enums
@using EventRescue
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IStringLocalizer<SharedResource> Localizer

@{
    ApplicationUser? layoutUser = null;
    if (SignInManager.IsSignedIn(User))
    {
        layoutUser = await UserManager.GetUserAsync(User);
    }

    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
 
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<!DOCTYPE html>
<html lang="@currentCulture" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventRescue</title>
    <script type="importmap"></script>
    
    @* تبديل ملف تنسيق Bootstrap لدعم اتجاهات الـ RTL بشكل حقيقي *@
    @if (isRtl)
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/eventrescue-pro.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventRescue.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    @if (currentCulture == "en")
    {
        <style>
            .navbar .nav-link, 
            .navbar .btn, 
            .navbar .dropdown-toggle,
            .navbar .dropdown-item {
                font-size: 0.9rem !important; /* يمكنك تعديل هذه القيمة لتصغيرها أكثر أو تكبيرها */
            }
        </style>
    }
</head>
<body class="d-flex flex-column min-vh-100" style="min-height: 100vh;">
    <header>
        <nav class="navbar navbar-expand-lg" style="background: rgba(255,255,255,.95); backdrop-filter: blur(12px); border-bottom: 1px solid #e2e8f0; box-shadow: 0 8px 25px rgba(15,23,42,.06); padding: 14px 0; position: relative; z-index: 1030;">
            <div class="container-fluid px-2 px-sm-3">
                
                <a class="navbar-brand ms-2" asp-controller="Home" asp-action="Index" style="font-size: 1.55rem; font-weight: 900; color: #1e3a8a !important; margin-right: 0;">
                    EventRescue
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" style="border-radius: 12px; padding: 8px 12px; outline: none; box-shadow: none;">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar" style="transition: .3s ease;">
                    <div class="d-lg-flex justify-content-lg-between w-100 align-items-center">
                        
                        <ul class="navbar-nav mb-2 mb-lg-0" style="gap: 6px;">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index"
                                   style="font-weight: 700; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                   onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                                   onmouseout="this.style.background='none'; this.style.color='#334155'">
                                    @Localizer["Layout_Home"]
                                </a>
                            </li>

                            @if (layoutUser != null && layoutUser.AccountType == UserType.Provider)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Providers" asp-action="AvailableRequests"
                                       style="font-weight: 700; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                       onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                                       onmouseout="this.style.background='none'; this.style.color='#334155'">
                                        @Localizer["Layout_AvailableRequests"]
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Providers" asp-action="MyTasks"
                                       style="font-weight: 700; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                       onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                                       onmouseout="this.style.background='none'; this.style.color='#334155'">
                                        @Localizer["Layout_MyTasks"]
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Emergency" asp-action="Index"
                                       style="font-weight: 700; color: #dc2626 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                       onmouseover="this.style.background='#fef2f2'; this.style.color='#dc2626'"
                                       onmouseout="this.style.background='none'; this.style.color='#dc2626'">
                                        @Localizer["Layout_EmergencyToday"]
                                    </a>
                                </li>
                            }

                            @if (layoutUser != null)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="EventRequests" asp-action="Create"
                                       style="font-weight: 700; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                       onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                                       onmouseout="this.style.background='none'; this.style.color='#334155'">
                                        @Localizer["Layout_IHaveEvent"]
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="EventRequests" asp-action="MyRequests"
                                       style="font-weight: 700; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                       onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                                       onmouseout="this.style.background='none'; this.style.color='#334155'">
                                        @Localizer["Layout_MyRequests"]
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"
                                       style="background: linear-gradient(135deg,#2563eb,#38bdf8); color: white !important; border-radius: 999px; padding: 10px 24px !important; transition: .25s ease; font-weight: 700; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                       onmouseover="this.style.background='linear-gradient(135deg,#1d4ed8,#0284c7)'"
                                       onmouseout="this.style.background='linear-gradient(135deg,#2563eb,#38bdf8)'">
                                        @Localizer["Layout_Dashboard"]
                                    </a>
                                </li>
                            }
                        </ul>

                        <ul class="navbar-nav me-2 align-items-lg-center" style="gap: 6px;">

                            <!-- زر وقائمة تبديل اللغة المحدثة لمنع الاقتصاص ومشاكل الظهور -->


<!-- ================== زر وقائمة تبديل اللغة (تم الإصلاح والتشغيل فوراً) ================== -->
<li class="nav-item dropdown" style="position: relative; list-style: none;">
    <button class="nav-link dropdown-toggle d-inline-flex align-items-center justify-content-center gap-2"
            id="langDropdown" data-bs-toggle="dropdown" aria-expanded="false" type="button"
            style="font-weight: 700; color: #334155 !important; padding: 8px 14px !important; border-radius: 999px; border: 1px solid #e2e8f0; background: transparent; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "0.9rem" : "1.05rem");">
        <i class="bi bi-globe2" style="font-size: 1.1rem;"></i>
        <span>@(currentCulture == "ar" ? Localizer["Layout_LangArabicLabel"] : Localizer["Layout_LangEnglishLabel"])</span>
    </button>
    
    <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2" aria-labelledby="langDropdown" 
        style="border-radius: 14px; min-width: 170px; margin-top: 8px; z-index: 1050;">
        <li>
            <form asp-controller="Language" asp-action="SetLanguage" asp-route-culture="ar" asp-route-returnUrl="@returnUrl" method="post" class="w-100 m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="dropdown-item d-flex align-items-center justify-content-between w-100" style="border-radius: 10px; font-weight: 700; padding: 10px 12px; border: none; background: none; text-align: start;">
                    <span>🇸🇦 @Localizer["Layout_LangArabicLabel"]</span>
                    @if (currentCulture == "ar")
                    {
                        <i class="bi bi-check-lg" style="color:#2563eb;"></i>
                    }
                </button>
            </form>
        </li>
        <li>
            <form asp-controller="Language" asp-action="SetLanguage" asp-route-culture="en-US" asp-route-returnUrl="@returnUrl" method="post" class="w-100 m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="dropdown-item d-flex align-items-center justify-content-between w-100" style="border-radius: 10px; font-weight: 700; padding: 10px 12px; border: none; background: none; text-align: start;">
                    <span>🇬🇧 @Localizer["Layout_LangEnglishLabel"]</span>
                    @if (currentCulture == "en")
                    {
                        <i class="bi bi-check-lg" style="color:#2563eb;"></i>
                    }
                </button>
            </form>
        </li>
    </ul>
</li>

                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Account" asp-action="Profile"
                                       style="font-weight: 700; color: #334155 !important; padding: 10px 16px !important; border-radius: 14px; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                       onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                                       onmouseout="this.style.background='none'; this.style.color='#334155'">
                                        @Localizer["Layout_Profile"]
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-link nav-link"
                                                style="font-weight: 700; color: #dc2626 !important; padding: 10px 16px !important; border-radius: 14px; transition: .25s ease; text-decoration: none; border: none; background: none; width: 100%; text-align: start; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                                onmouseover="this.style.background='#fef2f2';"
                                                onmouseout="this.style.background='none';">
                                            @Localizer["Layout_Logout"]
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Account" asp-action="Login"
                                       style="font-weight: 700; color: #334155 !important; padding: 10px 16px !important; border-radius: 14px; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");"
                                       onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                                       onmouseout="this.style.background='none'; this.style.color='#334155'">
                                        @Localizer["Layout_Login"]
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-primary" asp-controller="Account" asp-action="Register"
                                       style="border-radius: 999px; padding: 10px 25px; font-weight: 800; transition: .25s ease; white-space: nowrap; font-size: @(currentCulture == "en" ? "1.0rem" : "1.15rem");">
                                        @Localizer["Layout_CreateAccount"]
                                    </a>
                                </li>
                            }
                        </ul>

                    </div>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container flex-grow-1" style="flex: 1 0 auto;">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>
    
 <footer class="border-top footer text-muted">
        <div class="container text-center start-right">
            <p class="small mb-0 fw-bold text-secondary">
                EventRescue &copy; @DateTime.Now.Year - @(currentCulture == "ar" ? "جميع الحقوق محفوظة." : "All Rights Reserved.")
            </p>        
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
