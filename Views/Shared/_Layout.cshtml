@using Microsoft.AspNetCore.Identity
@using EventRescue.Models
@using EventRescue.Models.Enums
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    // نجيب المستخدم الحالي مرة واحدة لعرض الروابط حسب نوع حسابه
    ApplicationUser? layoutUser = null;
    if (SignInManager.IsSignedIn(User))
    {
        layoutUser = await UserManager.GetUserAsync(User);
    }
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
    <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventRescue</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/eventrescue-pro.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventRescue.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    
</head>
<body>
    <header>
<nav class="navbar navbar-expand-lg" style="background: rgba(255,255,255,.95); backdrop-filter: blur(12px); border-bottom: 1px solid #e2e8f0; box-shadow: 0 8px 25px rgba(15,23,42,.06); padding: 14px 0;">
    <!-- الحاوية ممتدة بالكامل لالتصاق العناصر بالحواف الجانبية -->
    <div class="container-fluid px-2 px-sm-3">
        
        <!-- الشعار (Brand) ملتصق باليمين تماماً (تم تكبيره إلى 1.55rem) -->
        <a class="navbar-brand ms-2" asp-controller="Home" asp-action="Index" style="font-size: 1.55rem; font-weight: 900; color: #1e3a8a !important; margin-right: 0;">
            EventRescue
        </a>

        <!-- زر التجاوب للجوال -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" style="border-radius: 12px; padding: 8px 12px; outline: none; box-shadow: none;">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- محتوى الناف بار المتجاوب -->
        <div class="collapse navbar-collapse" id="mainNavbar" style="transition: .3s ease;">
            
            <!-- حاوية مرنة ممتدة لتوزيع القائمتين: الروابط ملتصقة باليمين، والحساب ملتصق باليسار -->
            <div class="d-lg-flex justify-content-lg-between w-100 align-items-center">
                
                <!-- القائمة الأولى: الروابط الرئيسية ملتصقة بالشعار (تم تكبير الخط إلى 1.15rem مع تعديل الـ padding لتناسق الحجم) -->
                <ul class="navbar-nav mb-2 mb-lg-0" style="gap: 6px;">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index"
                           style="font-weight: 700; font-size: 1.15rem; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease;"
                           onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                           onmouseout="this.style.background='none'; this.style.color='#334155'">
                            الرئيسية
                        </a>
                    </li>

                    @* روابط المزود *@
                    @if (layoutUser != null && layoutUser.AccountType == UserType.Provider)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Providers" asp-action="AvailableRequests"
                               style="font-weight: 700; font-size: 1.15rem; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease;"
                               onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                               onmouseout="this.style.background='none'; this.style.color='#334155'">
                                الطلبات المتاحة
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Providers" asp-action="MyTasks"
                               style="font-weight: 700; font-size: 1.15rem; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease;"
                               onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                               onmouseout="this.style.background='none'; this.style.color='#334155'">
                                مهامي
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Emergency" asp-action="Index"
                               style="font-weight: 700; font-size: 1.15rem; color: #dc2626 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease;"
                               onmouseover="this.style.background='#fef2f2'; this.style.color='#dc2626'"
                               onmouseout="this.style.background='none'; this.style.color='#dc2626'">
                                طوارئ اليوم
                            </a>
                        </li>
                    }

                    @* روابط العميل *@
                    @if (layoutUser != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="EventRequests" asp-action="Create"
                               style="font-weight: 700; font-size: 1.15rem; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease;"
                               onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                               onmouseout="this.style.background='none'; this.style.color='#334155'">
                                عندي مناسبة
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="EventRequests" asp-action="MyRequests"
                               style="font-weight: 700; font-size: 1.15rem; color: #334155 !important; padding: 10px 18px !important; border-radius: 14px; transition: .25s ease;"
                               onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                               onmouseout="this.style.background='none'; this.style.color='#334155'">
                                طلباتي
                            </a>
                        </li>
                    }

                    @* رابط لوحة التحكم للمشرف *@
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"
                               style="background: linear-gradient(135deg,#2563eb,#38bdf8); color: white !important; border-radius: 999px; padding: 10px 24px !important; transition: .25s ease; font-weight: 700; font-size: 1.15rem;"
                               onmouseover="this.style.background='linear-gradient(135deg,#1d4ed8,#0284c7)'"
                               onmouseout="this.style.background='linear-gradient(135deg,#2563eb,#38bdf8)'">
                                لوحة التحكم
                            </a>
                        </li>
                    }
                </ul>

                <!-- القائمة الثانية: أزرار الحساب ملتصقة بأقصى الحافة اليسرى (تم تكبير الخط إلى 1.15rem) -->
                <ul class="navbar-nav me-2" style="gap: 6px;">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Profile"
                               style="font-weight: 700; font-size: 1.15rem; color: #334155 !important; padding: 10px 16px !important; border-radius: 14px; transition: .25s ease;"
                               onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                               onmouseout="this.style.background='none'; this.style.color='#334155'">
                                الملف الشخصي
                            </a>
                        </li>

                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link nav-link"
                                        style="font-weight: 700; font-size: 1.15rem; color: #dc2626 !important; padding: 10px 16px !important; border-radius: 14px; transition: .25s ease; text-decoration: none; border: none; background: none; width: 100%; text-align: start;"
                                        onmouseover="this.style.background='#fef2f2';"
                                        onmouseout="this.style.background='none';">
                                    تسجيل الخروج
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login"
                               style="font-weight: 700; font-size: 1.15rem; color: #334155 !important; padding: 10px 16px !important; border-radius: 14px; transition: .25s ease;"
                               onmouseover="this.style.background='#eff6ff'; this.style.color='#2563eb'"
                               onmouseout="this.style.background='none'; this.style.color='#334155'">
                                تسجيل الدخول
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-primary" asp-controller="Account" asp-action="Register"
                               style="border-radius: 999px; padding: 10px 25px; font-weight: 800; font-size: 1.15rem; transition: .25s ease;">
                                إنشاء حساب
                            </a>
                        </li>
                    }
                </ul>

            </div>

        </div>
    </div>
</nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center start-right">
         EventRescue - &copy; 2026 
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
