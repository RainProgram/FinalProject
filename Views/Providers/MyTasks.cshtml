@model List<EventRescue.Models.EventRequest>
@using EventRescue.Models.Enums

@{
    ViewData["Title"] = "مهامي";

    // نفصل المهام الجارية عن المنتهية (كلها رست على نفس المزود)
    var currentTasks = Model.Where(r => r.Status == EventStatus.Accepted).ToList();
    var archivedTasks = Model.Where(r => r.Status == EventStatus.Completed).ToList();
}

<div class="container py-4 er-page">

    <h3 class="mb-1"><i class="bi bi-list-check text-success"></i> مهامي</h3>
    <p class="er-muted mb-4">المهام التي اعتمدك العميل فيها — الجارية أولاً ثم أرشيف أعمالك</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ================== المهام الجارية ================== *@
    <h5 class="mt-4 mb-3">
        <i class="bi bi-lightning-charge-fill text-warning"></i>
        المهام الجارية
        <span class="badge bg-primary rounded-pill">@currentTasks.Count</span>
    </h5>

    @if (!currentTasks.Any())
    {
        <div class="er-card er-card-body text-center er-muted mb-4">
            <i class="bi bi-cup-hot d-block display-6 mb-2"></i>
            لا توجد مهام جارية — تابع <a asp-controller="Providers" asp-action="AvailableRequests">رادار الطلبات</a> وقدم عروضك
        </div>
    }

    <div class="row g-4 mb-5">
        @foreach (var task in currentTasks)
        {
            // السعر المتفق عليه = عرضي المقبول على هذا الطلب
            var acceptedOffer = task.ProviderOffers.FirstOrDefault(o => o.IsAccepted);

            <div class="col-lg-6">
                <div class="er-card er-card-body h-100">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-primary">
                            <i class="@task.Category?.Icon"></i> @task.Category?.Name
                        </span>
                        <span class="er-status er-status-accepted">
                            <i class="bi bi-check2-circle"></i> جارية
                        </span>
                    </div>

                    <h5>@task.Title</h5>
                    <p class="er-muted">@task.Description</p>

                    <ul class="list-unstyled small er-muted mb-3">
                        <li><i class="bi bi-geo-alt-fill"></i> @task.Region?.Name — @task.Address</li>
                        <li><i class="bi bi-calendar-event"></i> @task.EventDate.ToString("yyyy/MM/dd — hh:mm tt")</li>
                        @if (acceptedOffer != null)
                        {
                            <li><i class="bi bi-cash-stack"></i> السعر المتفق عليه: <strong>@acceptedOffer.Price ريال</strong></li>
                        }
                    </ul>

                    @* معلومات التواصل المباشر مع العميل — تظهر فقط بعد الاعتماد *@
                    <div class="alert alert-info py-2 mb-3">
                        <strong><i class="bi bi-person-fill"></i> العميل:</strong> @task.User?.FullName
                        <br />
                        <strong><i class="bi bi-telephone-fill"></i> الجوال:</strong>
                        <a href="tel:@task.User?.PhoneNumber" dir="ltr">@(task.User?.PhoneNumber ?? "لم يسجل رقم")</a>
                    </div>

                    <form asp-controller="Providers" asp-action="CompleteRequest" method="post"
                          onsubmit="return confirm('هل أتممت المهمة فعلاً؟ سيتم نقلها إلى الأرشيف');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="eventRequestId" value="@task.Id" />
                        <button type="submit" class="btn btn-outline-success er-btn w-100">
                            <i class="bi bi-check2-all"></i> إنهاء المهمة
                        </button>
                    </form>

                </div>
            </div>
        }
    </div>

    @* ================== أرشيف الأعمال المنتهية ================== *@
    <h5 class="mb-3">
        <i class="bi bi-archive-fill text-secondary"></i>
        أرشيف أعمالي
        <span class="badge bg-secondary rounded-pill">@archivedTasks.Count</span>
    </h5>

    @if (!archivedTasks.Any())
    {
        <div class="er-card er-card-body text-center er-muted">
            <i class="bi bi-archive d-block display-6 mb-2"></i>
            لا توجد أعمال منتهية بعد
        </div>
    }
    else
    {
        <div class="er-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>القسم</th>
                            <th>العنوان</th>
                            <th>العميل</th>
                            <th>المدينة</th>
                            <th>تاريخ المناسبة</th>
                            <th>الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in archivedTasks)
                        {
                            <tr>
                                <td><i class="@task.Category?.Icon"></i> @task.Category?.Name</td>
                                <td>@task.Title</td>
                                <td>@task.User?.FullName</td>
                                <td>@task.Region?.Name</td>
                                <td>@task.EventDate.ToString("yyyy/MM/dd")</td>
                                <td>
                                    <span class="er-status er-status-completed">
                                        <i class="bi bi-patch-check"></i> مكتمل
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>
