@model List<EventRescue.Models.EventRequest>

@{
    ViewData["Title"] = "الطلبات المتاحة";
    var currentProviderId = ViewBag.CurrentProviderId as string;
}

<div class="container py-4">

    <h3 class="mb-1"><i class="bi bi-broadcast text-danger"></i> رادار الطلبات المتاحة</h3>
    <p class="text-muted mb-4">الطلبات في مدينتك وضمن تخصصك فقط — الأقرب موعداً أولاً</p>

    @* رسائل النجاح والخطأ بعد تقديم العرض *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-light border text-center py-5">
            <i class="bi bi-inbox display-4 text-muted d-block mb-2"></i>
            لا توجد طلبات متاحة حالياً في مدينتك
        </div>
    }

    <div class="row g-4">
        @foreach (var request in Model)
        {
            // هل قدمتُ أنا عرضاً على هذا الطلب من قبل؟
            var myOffer = request.ProviderOffers
                .FirstOrDefault(o => o.ProviderId == currentProviderId);

            // فزعة عاجلة: المناسبة خلال أقل من 24 ساعة
            var isEmergency = request.EventDate <= DateTime.Now.AddHours(24);

            <div class="col-lg-6">
                <div class="card h-100 shadow-sm">

                    @if (!string.IsNullOrEmpty(request.ImagePath))
                    {
                        <img src="@request.ImagePath" class="card-img-top" alt="صورة الطلب"
                             style="height: 180px; object-fit: cover;" />
                    }

                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-primary">
                                <i class="@request.Category?.Icon"></i> @request.Category?.Name
                            </span>
                            @if (isEmergency)
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-alarm-fill"></i> فزعة عاجلة
                                </span>
                            }
                        </div>

                        <h5 class="card-title">@request.Title</h5>
                        <p class="card-text text-muted">@request.Description</p>

                        <ul class="list-unstyled small text-muted mb-3">
                            <li><i class="bi bi-geo-alt-fill"></i> @request.Region?.Name — @request.Address</li>
                            <li><i class="bi bi-calendar-event"></i> @request.EventDate.ToString("yyyy/MM/dd — hh:mm tt")</li>
                            <li><i class="bi bi-people-fill"></i> عدد العروض المقدمة: @request.ProviderOffers.Count</li>
                        </ul>

                        @if (myOffer != null)
                        {
                            <div class="alert alert-info mb-0 py-2">
                                <i class="bi bi-hourglass-split"></i>
                                قدمت عرضاً بسعر <strong>@myOffer.Price ريال</strong> — بانتظار رد العميل
                            </div>
                        }
                        else
                        {
                            @* فورم تقديم العرض: يرسل رقم الطلب (مخفي) + السعر إلى SendOffer *@
                            <form asp-controller="Providers" asp-action="SendOffer" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventRequestId" value="@request.Id" />
                                <div class="input-group">
                                    <span class="input-group-text">ريال</span>
                                    <input type="number" name="price" class="form-control"
                                           placeholder="أدخل سعر عرضك" min="1" max="100000" step="0.5" required />
                                    <button type="submit" class="btn btn-primary er-btn">
                                        <i class="bi bi-send-fill"></i> قدم عرض فزعة
                                    </button>
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

</div>
