@model EventRescue.Models.EventRequest
@using EventRescue.Models.Enums

@{
    ViewData["Title"] = "تفاصيل الطلب";

    string statusText = Model.Status switch
    {
        EventStatus.Pending => "متاح للعروض",
        EventStatus.Accepted => "مقبول",
        EventStatus.Completed => "مكتمل",
        EventStatus.Canceled => "ملغي",
        _ => "غير معروف"
    };

    string statusClass = Model.Status switch
    {
        EventStatus.Pending => "er-status-pending",
        EventStatus.Accepted => "er-status-accepted",
        EventStatus.Completed => "er-status-completed",
        EventStatus.Canceled => "er-status-canceled",
        _ => "er-status-pending"
    };

    string statusIcon = Model.Status switch
    {
        EventStatus.Pending => "bi-hourglass-split",
        EventStatus.Accepted => "bi-check2-circle",
        EventStatus.Completed => "bi-patch-check",
        EventStatus.Canceled => "bi-x-circle",
        _ => "bi-info-circle"
    };
}

<div class="container er-page mt-4 mb-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ================== الهيرو ================== *@
    <section class="er-hero mb-4">
        <div class="er-hero-content">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="er-badge">
                        <i class="bi bi-file-earmark-text"></i>
                        تفاصيل الطلب
                    </div>
                    <h1 class="er-title">@Model.Title</h1>
                    <p class="er-subtitle mb-0">
                        مراجعة كاملة لبيانات الطلب، الخدمة المطلوبة، الموقع، والحالة الحالية.
                    </p>
                </div>
                <div class="col-lg-4 text-lg-start text-center mt-4 mt-lg-0">
                    <span class="er-status @statusClass" style="font-size: 1rem; padding: 10px 20px;">
                        <i class="bi @statusIcon"></i>
                        @statusText
                    </span>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4">

        @* ================== صورة الطلب ================== *@
        <div class="col-lg-5">
            <div class="er-card overflow-hidden h-100">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" alt="صورة الطلب"
                         style="width: 100%; height: 420px; object-fit: cover;" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center"
                         style="height: 420px; background: var(--er-soft-blue); color: var(--er-blue); font-size: 4rem;">
                        <i class="bi bi-image"></i>
                    </div>
                }
                <div class="p-3 border-top er-muted small">
                    <i class="bi bi-info-circle text-primary"></i>
                    صورة الطلب تساعد مزود الخدمة على فهم المشكلة بشكل أسرع.
                </div>
            </div>
        </div>

        @* ================== بيانات الطلب ================== *@
        <div class="col-lg-7">
            <div class="er-card er-card-body h-100">

                <h5 class="fw-bold mb-3">وصف الطلب</h5>
                <div class="er-action mb-4" style="line-height: 1.9;">
                    @Model.Description
                </div>

                <h5 class="fw-bold mb-3">بيانات الطلب</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="er-action py-2 h-100">
                            <div class="d-flex align-items-center gap-2">
                                <span class="er-soft-icon"><i class="bi bi-tools"></i></span>
                                <div>
                                    <div class="er-muted small">نوع الخدمة</div>
                                    <div class="fw-bold">@(Model.Category?.Name ?? "غير محدد")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="er-action py-2 h-100">
                            <div class="d-flex align-items-center gap-2">
                                <span class="er-soft-icon"><i class="bi bi-geo-alt"></i></span>
                                <div>
                                    <div class="er-muted small">المدينة</div>
                                    <div class="fw-bold">@(Model.Region?.Name ?? "غير محددة")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="er-action py-2 h-100">
                            <div class="d-flex align-items-center gap-2">
                                <span class="er-soft-icon"><i class="bi bi-calendar-event"></i></span>
                                <div>
                                    <div class="er-muted small">موعد المناسبة</div>
                                    <div class="fw-bold">@Model.EventDate.ToString("yyyy/MM/dd — hh:mm tt")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="er-action py-2 h-100">
                            <div class="d-flex align-items-center gap-2">
                                <span class="er-soft-icon"><i class="bi bi-clock"></i></span>
                                <div>
                                    <div class="er-muted small">تاريخ إرسال الطلب</div>
                                    <div class="fw-bold">@Model.CreatedAt.ToString("yyyy/MM/dd")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="er-action py-2">
                            <div class="d-flex align-items-center gap-2">
                                <span class="er-soft-icon"><i class="bi bi-house-door"></i></span>
                                <div>
                                    <div class="er-muted small">العنوان / الحي</div>
                                    <div class="fw-bold">@Model.Address</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ================== قسم العروض (Services Module) ================== *@

                @if (Model.Status == EventStatus.Accepted && Model.AcceptedProvider != null)
                {
                    <h5 class="fw-bold mb-3">الفني المعتمد</h5>
                    <div class="er-action mb-4" style="background: #dcfce7; border-color: #86efac;">
                        <div class="d-flex align-items-center gap-2">
                            <span class="er-soft-icon" style="background: #bbf7d0; color: #166534;">
                                <i class="bi bi-patch-check-fill"></i>
                            </span>
                            <div>
                                <div class="fw-bold">@Model.AcceptedProvider.FullName</div>
                                <a href="tel:@Model.AcceptedProvider.PhoneNumber" class="small" dir="ltr">
                                    <i class="bi bi-telephone-fill"></i> @(Model.AcceptedProvider.PhoneNumber ?? "لم يسجل رقم جوال")
                                </a>
                            </div>
                        </div>
                        <span class="er-status er-status-completed">تواصلي معه الآن</span>
                    </div>
                }
                else if (Model.Status == EventStatus.Pending)
                {
                    <h5 class="fw-bold mb-3">العروض المقدمة (@Model.ProviderOffers.Count)</h5>

                    @if (!Model.ProviderOffers.Any())
                    {
                        <div class="er-action mb-4 justify-content-center er-muted">
                            <span>
                                <i class="bi bi-hourglass"></i>
                                لا توجد عروض بعد — سيظهر طلبك للفنيين المتخصصين في مدينتك
                            </span>
                        </div>
                    }
                    else
                    {
                        <div class="d-grid gap-2 mb-4">
                            @foreach (var offer in Model.ProviderOffers.OrderBy(o => o.Price))
                            {
                                <div class="er-action py-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="er-soft-icon"><i class="bi bi-person-badge"></i></span>
                                        <div>
                                            <div class="fw-bold">@(offer.Provider?.FullName ?? "فني")</div>
                                            <div class="er-muted small">
                                                <i class="bi bi-cash-stack"></i> @offer.Price ريال
                                                &nbsp;•&nbsp;
                                                <i class="bi bi-clock"></i> @offer.OfferDate.ToString("yyyy/MM/dd — hh:mm tt")
                                            </div>
                                        </div>
                                    </div>
                                    <form asp-controller="Providers" asp-action="AcceptOffer" method="post"
                                          onsubmit="return confirm('اعتماد هذا الفني وقبول عرضه؟');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="offerId" value="@offer.Id" />
                                        <button type="submit" class="btn btn-success er-btn">
                                            <i class="bi bi-check2-circle"></i> موافقة
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                }

                @* ================== الأزرار ================== *@
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 border-top pt-3">
                    <a asp-action="MyRequests" class="btn btn-outline-primary er-btn">
                        <i class="bi bi-arrow-right"></i>
                        العودة إلى طلباتي
                    </a>

                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.Status == EventStatus.Pending)
                        {
                            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post"
                                  onsubmit="return confirm('هل أنت متأكد من إلغاء هذا الطلب؟');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger er-btn">
                                    <i class="bi bi-x-circle"></i>
                                    إلغاء الطلب
                                </button>
                            </form>
                        }
                        <a asp-action="Create" class="btn btn-primary er-btn">
                            <i class="bi bi-plus-circle"></i>
                            طلب جديد
                        </a>
                    </div>
                </div>

            </div>
        </div>

    </div>

</div>
