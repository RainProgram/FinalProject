@model List<EventRescue.Models.EventRequest>
@using EventRescue.Models.Enums

@{
    ViewData["Title"] = "الطلبات - EventRescue";
    var selectedStatus = ViewBag.SelectedStatus as EventStatus?;
}

<style>
    :root {
        --er-blue: #2563eb;
        --er-soft-blue: #eff6ff;
    }

    .er-page {
        direction: rtl;
    }

    .er-hero {
        border-radius: 28px;
        overflow: hidden;
        background:
            radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.30), transparent 45%),
            linear-gradient(135deg, #1e293b, #0f172a 70%);
        border: none;
        position: relative;
    }

    .er-hero-content {
        padding: 32px 40px;
        position: relative;
        z-index: 1;
    }

    .er-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.14);
        color: #cbd5e1;
        border-radius: 999px;
        padding: 8px 16px;
        font-weight: 800;
        font-size: 0.88rem;
        margin-bottom: 14px;
    }

    .er-title {
        font-weight: 900;
        color: #ffffff;
    }

    .er-subtitle {
        color: #94a3b8;
    }

    .er-btn {
        border-radius: 999px;
        font-weight: 800;
        padding: 10px 22px;
    }

    .er-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .er-card-body {
        padding: 22px;
    }

    .er-card-header {
        padding: 18px 22px;
        border-bottom: 1px solid #f1f5f9;
        font-weight: 900;
        color: #0f172a;
    }

    .er-filter {
        border-radius: 999px;
        padding: 9px 18px;
        font-weight: 800;
        font-size: 0.9rem;
        border: 1px solid #e2e8f0;
        color: #475569;
        background: white;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: 0.2s ease;
    }

    .er-filter:hover { border-color: #bfdbfe; color: var(--er-blue); }

    .er-filter.active-all { background: #f1f5f9; border-color: #cbd5e1; color: #334155; }
    .er-filter.active-pending { background: #fff7ed; border-color: #fdba74; color: #c2410c; }
    .er-filter.active-accepted { background: #e0f2fe; border-color: #7dd3fc; color: #0369a1; }
    .er-filter.active-completed { background: #dcfce7; border-color: #86efac; color: #166534; }
    .er-filter.active-canceled { background: #fee2e2; border-color: #fca5a5; color: #991b1b; }

    .er-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin-bottom: 0;
    }

    .er-table thead th {
        color: #64748b;
        font-weight: 800;
        font-size: 0.85rem;
        padding: 12px 14px;
        border-bottom: 2px solid #f1f5f9;
        text-align: right;
        white-space: nowrap;
    }

    .er-table tbody td {
        padding: 14px;
        color: #1e293b;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }

    .er-table tbody tr:hover { background: #f8fafc; }

    .er-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 0.8rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .er-status-pending { background: #fff7ed; color: #c2410c; }
    .er-status-accepted { background: #e0f2fe; color: #0369a1; }
    .er-status-completed { background: #dcfce7; color: #166534; }
    .er-status-canceled { background: #fee2e2; color: #991b1b; }

    .er-empty {
        text-align: center;
        padding: 40px 20px;
        color: #94a3b8;
    }
</style>

<div class="container er-page mt-4 mb-5">

    @* ================== الهيرو ================== *@
    <section class="er-hero mb-4">
        <div class="er-hero-content">
            <div class="er-badge">
                <i class="bi bi-clipboard-data-fill"></i>
                إدارة الطلبات
            </div>
            <h1 class="er-title fs-3">كل الطلبات</h1>
            <p class="er-subtitle mb-0">عرض كل الطلبات مع إمكانية الفلترة حسب الحالة.</p>
        </div>
    </section>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-action="Requests" class="er-filter @(selectedStatus == null ? "active-all" : "")">الكل</a>
        <a asp-action="Requests" asp-route-status="Pending" class="er-filter @(selectedStatus == EventStatus.Pending ? "active-pending" : "")">متاحة</a>
        <a asp-action="Requests" asp-route-status="Accepted" class="er-filter @(selectedStatus == EventStatus.Accepted ? "active-accepted" : "")">مقبولة</a>
        <a asp-action="Requests" asp-route-status="Completed" class="er-filter @(selectedStatus == EventStatus.Completed ? "active-completed" : "")">مكتملة</a>
        <a asp-action="Requests" asp-route-status="Canceled" class="er-filter @(selectedStatus == EventStatus.Canceled ? "active-canceled" : "")">ملغاة</a>
    </div>

    <div class="er-card">
        <div class="er-card-header">
            عدد النتائج: @Model.Count
        </div>
        <div class="er-card-body">
            <div class="table-responsive">
                <table class="er-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>العنوان</th>
                            <th>العميل</th>
                            <th>القسم</th>
                            <th>المنطقة</th>
                            <th>الحالة</th>
                            <th>تاريخ الإنشاء</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="er-empty">لا توجد طلبات</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var req in Model)
                            {
                                string statusText = req.Status switch
                                {
                                    EventStatus.Pending => "متاح للعروض",
                                    EventStatus.Accepted => "مقبول",
                                    EventStatus.Completed => "مكتمل",
                                    EventStatus.Canceled => "ملغي",
                                    _ => req.Status.ToString()
                                };

                                string statusClass = req.Status switch
                                {
                                    EventStatus.Pending => "er-status-pending",
                                    EventStatus.Accepted => "er-status-accepted",
                                    EventStatus.Completed => "er-status-completed",
                                    EventStatus.Canceled => "er-status-canceled",
                                    _ => "er-status-pending"
                                };

                                string statusIcon = req.Status switch
                                {
                                    EventStatus.Pending => "bi-hourglass-split",
                                    EventStatus.Accepted => "bi-check2-circle",
                                    EventStatus.Completed => "bi-patch-check",
                                    EventStatus.Canceled => "bi-x-circle",
                                    _ => "bi-info-circle"
                                };

                                <tr>
                                    <td>@req.Id</td>
                                    <td class="fw-bold">@req.Title</td>
                                    <td>@(req.User?.FullName ?? "-")</td>
                                    <td>@(req.Category?.Name ?? "-")</td>
                                    <td>@(req.Region?.Name ?? "-")</td>
                                    <td><span class="er-status @statusClass"><i class="bi @statusIcon"></i>@statusText</span></td>
                                    <td>@req.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex justify-content-center">
        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-primary er-btn px-4">
            <i class="bi bi-arrow-right"></i>
            رجوع 
        </a>
    </div>

</div>
